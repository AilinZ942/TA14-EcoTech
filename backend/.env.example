# Local development login
APP_USERNAME=admin
APP_PASSWORD=password
SECRET_KEY=dev-secret-key-change-this

# Optional database settings for real dashboard/disposal data
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotech
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_SSLMODE=prefer

# Set true only when running behind HTTPS in production
SESSION_COOKIE_SECURE=false
